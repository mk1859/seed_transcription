# inhibition of expression up-regulation by amanitin at 6h (Fig. S1C)
plot <- read.table("qPCR/alpha_norm_data.txt",header=T, dec = ",")
plot$sample <- factor (plot$sample, levels = c("int_wat","int_amm", "scar_wat","scar_amm"))

ggplot(plot, aes(x = sample, y = hsp17, color = rep, group = sample)) +
  geom_jitter(width = 0.08, height = 0.0) +
  theme_classic() +
  theme(legend.position = "none") + 
  scale_color_tableau() + 
  geom_hpline(stat = "summary") +
  ylim(0,1.5)

t.test (plot$hsp17 [which(plot$sample == "int_wat")], plot$hsp17 [which(plot$sample == "int_amm")], var.equal = T)$p.value
t.test (plot$hsp17 [which(plot$sample == "scar_wat")], plot$hsp17 [which(plot$sample == "scar_amm")], var.equal = T)$p.value

ggplot(plot, aes(x = sample, y = sro5, color = rep, group = sample)) +
  geom_jitter(width = 0.08, height = 0.0) +
  theme_classic() +
  theme(legend.position = "none") + 
  scale_color_tableau() + 
  geom_hpline(stat = "summary") +
  ylim(0,2)

t.test (plot$sro5 [which(plot$sample == "int_wat")], plot$sro5 [which(plot$sample == "int_amm")], var.equal = T)$p.value
t.test (plot$sro5 [which(plot$sample == "scar_wat")], plot$sro5 [which(plot$sample == "scar_amm")], var.equal = T)$p.value


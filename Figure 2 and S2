# function to calculate labeling percentage.
calculate_labeling_percentage <- function(cpm_data, deseq_results, time_column) {
  genes <- cpm_data$gene[cpm_data[[time_column]] > 1] 
  genes <- genes[genes %in% araport$gene[araport$attribute == "protein_coding"]]
  lab_mRNA <- genes[genes %in% deseq_results$gene[deseq_results$change == "NEW"]]
  return(length(lab_mRNA) / length(genes))
}


# function to generate plots for new mRNA identification

new_mRNA_plot <- function(cpm_data, deseq_results, gene_list, condition_new, condition_inp, return_data = FALSE, highlight = NULL) {
  # merge datasets and separate normalisation genes
  plot <- merge(cpm_data, deseq_results, by = "gene")
  ercc <- plot[plot$gene %in% gene_list & plot[[condition_new]] > 1, ]
  highlight <- plot[plot$gene %in% highlight, ]
  plot <- plot[!plot$gene %in% c(gene_list,highlight) , ]
  plot$log2FoldChange[is.na(plot$log2FoldChange) | plot$padj > 0.05] <- 0
  param <- coef(summary(lm(log10(ercc[[condition_new]]) ~ log10(ercc[[condition_inp]])))) # fit linear model
  
  # generate plot
  p <- ggplot() +
    geom_point(data = plot, aes(x = log10(plot[[condition_inp]]), y = log10(plot[[condition_new]]), color = log2FoldChange), size = 0.5) +
    geom_point(data = ercc, aes(x = log10(ercc[[condition_inp]]), y = log10(ercc[[condition_new]])), size = 1, color = "#cc3a3d") +
    geom_point(data = highlight, aes(x = log10(highlight[[condition_inp]]), y = log10(highlight[[condition_new]])), size = 1, color = "#fcab20") +
    geom_text_repel(data = highlight, aes(x = log10(highlight[[condition_inp]]), y = log10(highlight[[condition_new]]),label = gene),box.padding = 0.5, max.overlaps = Inf) +
    geom_abline(intercept = param[1, 1], slope = param[2, 1], color = "red", linewidth = 0.5, linetype = "dashed") +
    scale_color_gradient(low = "#7f9bb0", high = "#26456e", limits = c(2, 10)) +
    xlim(-1, 5) + ylim(-1, 5) +
    xlab("log10(CPM) input") + ylab("log10(CPM) new") +
    theme_classic() 
  
  if (return_data) {
    return(list(plot = plot, ercc = ercc))
  } else {
    return(p)
  }
}


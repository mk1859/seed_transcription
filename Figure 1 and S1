# summary for differentially expressed genes

# function to summarise a list of DESeq2 results, returning lists of genes with significantly changed mRNA levels

process_deg_data <- function(deg_list, lfc_threshold = 1) {
  up <- list()
  dw <- list()
  for (i in seq_along(deg_list)) {
    x <- as.data.frame(deg_list[[i]])
    up[[i]] <- x$gene[which(x$padj < 0.05 & x$log2FoldChange > lfc_threshold)]
    dw[[i]] <- x$gene[which(x$padj < 0.05 & x$log2FoldChange < -lfc_threshold)]
  }
  names(up) <- names(deg_list)
  names(dw) <- names(deg_list)
  return(list(up = up, dw = dw))
}


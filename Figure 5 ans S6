# function for new mRNA calling when comparing new mRNA-enriched and input samples without filtering for the type of genes
new_identification_2 <- function(counts_matrix, coldata, rows1, rows2, 
                                 min_counts = 4, normalization_genes) {
  
  coldata_subset <- coldata[c(rows1, rows2), ]
  counts_matrix_subset <- counts_matrix[, coldata_subset$lib]
  condition1 <- as.character(unique(coldata$condition[rows1]))
  condition2 <- as.character(unique(coldata$condition[rows2]))
  dds <- DESeqDataSetFromMatrix(countData = counts_matrix_subset, 
                                colData = coldata_subset, 
                                design = ~ replicate + condition)
  
  dds <- estimateSizeFactors(dds, controlGenes = rownames(counts_matrix_subset) %in% normalization_genes)
  dds <- dds[rowSums(counts(dds) >= min_counts) >= min_counts, ]
  dds <- DESeq(dds)
  
  contrast <- c("condition", condition1, condition2)
  res <- as.data.frame(results(dds, alpha = 0.05, contrast = contrast))
  res$gene <- rownames(res)
  res$change <- "NO"
  res$change <- ifelse(res$padj < 0.05 & res$log2FoldChange > 2, "NEW", res$change)
  res$change <- factor(res$change, levels = c("NEW", "NO"))
  
  return(res)
}


genes <- genes [which(genes %in% araport$gene [which(araport$attribute == "protein_coding")])]
genes <- genes [-c(grep ("ATM", genes),grep ("ATC", genes))]

# calculate CPMs and z-scores
cpm <- temp_imb_inp
depth <- colSums(cpm)

## Analysis of total mRNA stability changes during CHX treatment. 

# import and format count data
dir <- "geo_counts/stability/"
files <- list.files(dir, pattern = "*.txt", full.names = TRUE)
stabil <- lapply(files, fread)
count_matrix <- do.call(cbind, lapply(stabil, function(df) df$V2))
rownames(count_matrix) <- stabil[[1]]$V1
colnames(count_matrix) <- gsub(".txt", "", basename(files))
stabil <- count_matrix

# ERCC spike-ins are used to normalise the dataset
coldata <- data.frame(lib = colnames (stabil),
                      condition = substr (colnames (stabil), 1, 4),
                      replicate = substr (colnames (stabil), 6, 6))

ercc <- rownames (stabil)[grep ("ERCC", rownames(stabil))]

dds <- DESeqDataSetFromMatrix(countData = stabil, colData = coldata, design = ~ condition)
dds <- estimateSizeFactors(dds, controlGenes= rownames(stabil) %in% ercc)
dds <- DESeq(dds)

# PCA plot (Fig. S3K)
plot <- plotPCA(rlogTransformation(dds, blind=TRUE), intgroup=c('condition'), ntop = 1000, returnData=TRUE)
percentVar <- round(100 * attr(plot, "percentVar"))

ggplot(plot , aes(x=PC1, y=PC2, color = group)) +
  geom_point(size = 3) + 
  theme_classic() +
  scale_color_manual(values=c("#ffb022","#ff810e","#c23728",
                              "#7f7f7f",
                              "#63bff0","#22a7f0", "#1984c5")) +
  xlab(paste0("PC1: ",percentVar[1],"% variance")) +
  ylab(paste0("PC2: ",percentVar[2],"% variance")) + 
  coord_fixed()

# differential gene expression analysis for relevant pairwise comparisons
contrast_list <- list(
  "M_01_00" = c("M_1h", "D_0h"), "M_03_00" = c("M_3h", "D_0h"), "M_06_00" = c("M_6h", "D_0h"),
  "C_01_00" = c("C_1h", "D_0h"), "C_03_00" = c("C_3h", "D_0h"), "C_06_00" = c("C_6h", "D_0h"),
  "t01_C_M" = c("C_1h", "M_1h"), "t03_C_M" = c("C_3h", "M_3h"), "t06_C_M" = c("C_6h", "M_6h")
)

deg_cyclo <- setNames(
  lapply(names(contrast_list), function(name) {
    c <- contrast_list[[name]]
    res <- results(dds, alpha = 0.05, contrast = c("condition", c[1], c[2]))
    res$gene <- rownames(res)
    res
  }),
  names(contrast_list)
)


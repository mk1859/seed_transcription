# gene expression clustering through identifying WGCNA modules

# select mRNAs affected during mock imbibition
imb_genes <- unlist(process_deg_data(deg_alpha[c(1:4, 9:11)]))
imb_genes <- imb_genes [!duplicated(imb_genes)]

# We used 3'RNA-seq relying on poly(A) tails, so we focus on nuclear protein-coding genes to exclude possible off-targets.
imb_genes <- imb_genes [which(imb_genes %in% araport$gene [which(araport$attribute == "protein_coding")])]
imb_genes <- imb_genes [-c(grep ("ATM", imb_genes),grep ("ATC", imb_genes))]

# calculate CPMs for the whole experiment
cpm <- ath
depth <- colSums(cpm)
cpm <- t(t(cpm) / depth) * 10^6
cpm <- cpm[, -grep("_A_", colnames(cpm))]   # remove ABA samples

# calculate z-scores
zscore_alpha <- t(scale(t(cpm)))
colnames(zscore_alpha) <- colnames(cpm)
rownames(zscore_alpha) <- rownames(cpm)

# subset z-scores to selected genes and transpose
selected_genes <- as.data.frame(t(zscore_alpha[rownames(zscore_alpha) %in% imb_genes, ])) 

# calculate mean expression per condition and select mock
selected_genes$condition <- factor(gsub('.{0,3}$', '', rownames(selected_genes)))
selected_genes <- as.data.frame(t(apply (selected_genes [,-ncol(selected_genes)], 2, function (x) {
  tapply (x, selected_genes$condition, mean)})))

mock <- selected_genes [,c(5:9)]

# identification of WGCNA gene expression modules for mock imbibition
net <- blockwiseModules(t(mock), power = 10,
                        TOMType = "signed", minModuleSize = 30, deepSplit = 2, mergeCutHeight = 0.25,
                        numericLabels = TRUE, networkType = "signed",
                        saveTOMs = TRUE, saveTOMFileBase = "test",
                        verbose = 3, maxBlockSize = 4000)

# add module assignments and gene names
mock$cluster <- factor(net$colors, levels = c(3, 1, 2, 4, 0), labels = c("C1", "C2", "C3", "C4", "C0"))
mock$gene <- rownames(mock)

# save the module assignment
clusters_alpha <- mock[, c("gene", "cluster")] 


smFISH_dataset_2_nuc <- smFISH_dataset_2 %>% 
  filter(component %in% c("Nucleus", "Mixed"))

# select top N-2 brightest objects in nucleus/mixed
smFISH_dataset_2_nuc_sel <- smFISH_dataset_2_nuc %>% 
  group_by(name) %>% 
  arrange(desc(pixel_bright_sum_per_comp), .by_group=TRUE) %>% dplyr::slice(-(1:2))

# calculate median brightness per cell without the two brightest dots in the nucleus
med_brightness <- bind_rows(smFISH_dataset_2_cyt, smFISH_dataset_2_nuc_sel) %>%
  group_by(name) %>%
  summarise(med_brightness = median(pixel_bright_sum_per_comp))

# merge and calculate fold change
brightness_nucleus_FC <- smFISH_dataset_2_nuc %>%
  left_join(med_brightness, by = "name") %>%
  mutate(fold_change_brightness = pixel_bright_sum_per_comp / med_brightness)

# filter for transcription sites (fold change >= 1.5)
transcription_sites <- brightness_nucleus_FC %>%
  filter(fold_change_brightness >= 1.5)

# select top 2 transcription sites per cell
transcription_sites_2n <- transcription_sites %>%
  group_by(name) %>%
  arrange(desc(fold_change_brightness), .by_group = TRUE) %>%
  dplyr::slice(1:2)

# process time point labels
transcription_sites_2n <- transcription_sites_2n %>%
  mutate(type = factor(substr(name, 1, 1), levels = c("D", "1", "3"),

background <- background [which(background %in% araport$gene [which(araport$attribute == "protein_coding")])]
plot <- list ()

res <- gost(query = clusters_maturation_new$gene [which(clusters_maturation_new$cluster == "M15")], organism = "athaliana", custom_bg = background, user_threshold = 0.05)$result
plot$M15 <- res [c(1,2,4,5,6,8,12),c(11,3,10)]

res <- gost(query = clusters_maturation_new$gene [which(clusters_maturation_new$cluster == "M22")], organism = "athaliana", custom_bg = background, user_threshold = 0.05)$result
plot$M22 <- res [c(1,3,7,10),c(11,3,10)]

res <- gost(query = clusters_maturation_new$gene [which(clusters_maturation_new$cluster == "M26")], organism = "athaliana", custom_bg = background, user_threshold = 0.05)$result
plot$M26 <- res [c(5,6,7,8,10,11,12),c(11,3,10)]

plot <- rbindlist(plot, idcol = "cluster")
plot$order <- factor(paste(plot$term_name, 1:nrow(plot)), levels = rev(paste(plot$term_name, 1:nrow(plot))))
plot$log <-  -log10(plot$p_value)

ggplot(data=plot, aes(x=order, y=log)) +
  geom_bar(stat="identity", fill = "lightgrey")+ 
  theme_classic() +
  theme (legend.position = "none",
         axis.title.y=element_blank()) +
  coord_flip() +
  scale_x_discrete(labels=rev(plot$term_name))

### New mRNA production - effects of imbibition and maturation conditions (Figure 4, S4 and S5).

library (DESeq2)
library (tidyverse)
library (WGCNA)
library (cowplot)
library (gprofiler2)
library (data.table)
library (statforbiology)
library (multcomp)
library (multcompView)
library (ggrepel)
library (ggvenn)
library (scales)

# set the path to folder containing the data
setwd("/data/")

## Experiment on temperatures during imbibition.

# import of counts for input
dir <- "geo_counts/temp_imb/input/"
files <- list.files(dir, pattern = "*.txt", full.names = TRUE)
temp_imb_inp <- lapply(files, fread)
count_matrix <- do.call(cbind, lapply(temp_imb_inp, function(df) df$V2))
rownames(count_matrix) <- temp_imb_inp[[1]]$V1
colnames(count_matrix) <- gsub(".txt", "", basename(files))
temp_imb_inp <- count_matrix

## differential gene expression during imbibition (Fig. S4B).
ercc <- grep ("ERCC", rownames(temp_imb_inp))
coldata <- data.frame(lib = colnames (temp_imb_inp),
                      condition = substr (colnames (temp_imb_inp), 1, 3),
                      replica = as.factor(seq(1:4)))

dds <- DESeqDataSetFromMatrix(countData = temp_imb_inp [-ercc,], colData = coldata, design = ~ condition)
dds <- DESeq(dds)

contrast_list <- list("inp_22_04" = c("t22","t04"), "inp_35_22" = c("t35","t22"), "inp_35_04" = c("t35","t04"))

deg_temp <- setNames(
  lapply(names(contrast_list), function(name) {
    c <- contrast_list[[name]]
    res <- results(dds, alpha = 0.05, contrast = c("condition", c[1], c[2]))
    res$gene <- rownames(res)
    res$change <- "NO"
    res$change <-   ifelse (res$padj < .05 & res$log2FoldChange < -1, "DW", res$change)
    res$change <-   ifelse (res$padj < .05 & res$log2FoldChange > 1, "UP", res$change)
    res$change <-   factor(res$change, levels = c("UP", "DW", "NO"))
    res
  }),
  names(contrast_list)
)

create_volcano_plot (deg_temp$inp_22_04, lfc_cap = 5, padj_cap = 100)
create_volcano_plot (deg_temp$inp_35_22, lfc_cap = 5, padj_cap = 100)
create_volcano_plot (deg_temp$inp_35_04, lfc_cap = 5, padj_cap = 100)

# gene expression clustering during imbibition in different temperatures
# select and filter genes with expression affected
genes <- unlist(process_deg_data(deg_temp))
genes <- genes [!duplicated(genes)]
genes <- genes [which(genes %in% araport$gene [which(araport$attribute == "protein_coding")])]
genes <- genes [-c(grep ("ATM", genes),grep ("ATC", genes))]

# calculate CPMs and z-scores
cpm <- temp_imb_inp
depth <- colSums(cpm)
cpm <- t(t(cpm) / depth) * 10^6
zscore_temp_inp <- t(scale(t(cpm)))
colnames(zscore_temp_inp) <- colnames(cpm)
rownames(zscore_temp_inp) <- rownames(cpm)

# clustering and heatmap for genes affected during imbibition (Fig. S4C)
selected_genes <- as.data.frame(t(zscore_temp_inp[rownames(zscore_temp_inp) %in% genes, ])) 
selected_genes$condition <- factor(gsub('.{0,4}$', '', rownames(selected_genes)))
selected_genes <- as.data.frame(t(apply (selected_genes [,-ncol(selected_genes)], 2, function (x) {
  tapply (x, selected_genes$condition, mean)})))

net <- blockwiseModules(t(selected_genes), power = 7, checkMissingData =F,
                        TOMType = "signed", minModuleSize = 30, deepSplit = 1, mergeCutHeight = 0.25,
                        numericLabels = TRUE, networkType = "signed",
                        saveTOMs = TRUE, saveTOMFileBase = "test",
                        verbose = 3, maxBlockSize = 4000)

selected_genes <- selected_genes %>%
  mutate(cluster = net$colors,
         gene = rownames(.),
         cluster = if_else(cluster == 0, NA_integer_, cluster)) %>% 
  filter(!is.na(cluster)) %>% 
  arrange(cluster) %>% 
  mutate(cluster = factor(cluster, levels = c(1, 2, 3), labels = c("G4", "G22", "G35")), 
         gene = factor(gene, levels = gene)) 

clusters_temp_inp <- selected_genes [,4:5]

selected_genes <- pivot_longer(selected_genes,cols = t04:t35, names_to = "condition", values_to = "level")

p1 <- ggplot(selected_genes, aes(x = condition, y = gene, fill = level)) +
  geom_tile() +
  scale_fill_gradient2(low = "#3e446e", mid = "white", high = "#cc3a3d", midpoint = 0, limits = range(selected_genes$level, na.rm = TRUE)) +
  theme_classic() +
  theme(axis.line.y = element_blank(), axis.ticks.y = element_blank(),
        axis.title.y = element_blank(), axis.text.y = element_blank(),
        axis.line.x = element_blank(), axis.ticks.x = element_blank(),
        axis.title.x = element_blank())

p2 <- ggplot(selected_genes, aes(x = "x", y = gene, fill = cluster)) +
  geom_tile() +
  theme_classic() +
  theme(axis.line = element_blank(), axis.ticks = element_blank(),
        axis.title = element_blank(), axis.text.y = element_blank(),
        legend.position = "none") +
  scale_fill_manual(values = c("#0183acff", "#95c773ff", "#cd3337ff"))

plot_grid(p2, p1, nrow = 1, rel_widths = c(0.6, 1.5), align = 'hv')

# GO terms enriched in clusters (Fig. S4C)
background <- araport$gene [which(araport$attribute == "protein_coding")]  

plot <- list()
res <- gost(query = clusters_temp_inp$gene [which(clusters_temp_inp$cluster == "G4")], organism = "athaliana", custom_bg = background, user_threshold = 0.05)$result
plot$G4 <- res [c(1,2,5,6,11,22,34,35,38,45,61,69,75,85,87),c(11,3,10)]

res <- gost(query = clusters_temp_inp$gene [which(clusters_temp_inp$cluster == "G22")], organism = "athaliana", custom_bg = background, user_threshold = 0.05)$result
plot$G22 <- res [c(4,9,12,14,19),c(11,3,10)]

res <- gost(query = clusters_temp_inp$gene [which(clusters_temp_inp$cluster == "G35")], organism = "athaliana", custom_bg = background, user_threshold = 0.05)$result
plot$G35 <- res [c(1,6,10,13),c(11,3,10)]

plot <- rbindlist(plot, idcol = "cluster")
plot$order <- factor(paste(plot$term_name, 1:nrow(plot)), levels = rev(paste(plot$term_name, 1:nrow(plot))))
plot$log <-  -log10(plot$p_value)

ggplot(data=plot, aes(x=order, y=log)) +
  geom_bar(stat="identity", fill = "lightgrey")+ 
  theme_classic() +
  theme (legend.position = "none",
         axis.title.y=element_blank()) +
  coord_flip() +
  scale_x_discrete(labels=rev(plot$term_name))


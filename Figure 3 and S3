# function to perform Fisher's test for a given cluster
perform_fisher_test <- function(cluster_row, data_matrix, change_col, other_cols) {
  a <- data_matrix[cluster_row, change_col]
  b <- sum(data_matrix[cluster_row, other_cols])
  d <- sum(data_matrix[-cluster_row, change_col])
  e <- sum(data_matrix[-cluster_row, other_cols])
  fisher.test(as.table(matrix(c(a, d, b, e), nrow = 2, byrow = TRUE)), alternative = "greater")$p.value
}

# perform Fisher's tests for 'DOWN' changes against 'NO' and 'UP'

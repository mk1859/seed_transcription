# differential gene expression in total mRNA samples upon cycloheximide treatment

# It was reported that CHX treatment may affect the stability of the mRNA genome-wide.
# That is why we use ERCC normalisation even for total mRNA differential analysis.

# function for DEG identification in total MRNA samples
deg_total <- function(counts_matrix, coldata, rows1, rows2, normalization_genes = rownames(counts_matrix)) {
  # subset coldata based on row numbers
  coldata_subset <- coldata[c(rows1, rows2), ]
  # subset counts matrix to match the subsetted coldata and remove ERCC
  counts_matrix_subset <- counts_matrix[-grepl("ERCC", rownames(counts_matrix)), coldata_subset$lib]
  
  condition1 <- unique(coldata$condition[rows1]) #Extract condition names for the contrast
  condition2 <- unique(coldata$condition[rows2])
  
  dds <- DESeqDataSetFromMatrix(countData = counts_matrix_subset, 
                                colData = coldata_subset, 
                                design = ~ condition)
  dds <- estimateSizeFactors(dds, controlGenes = rownames(counts_matrix_subset) %in% normalization_genes)
  dds <- DESeq(dds)
  
  # ensure the contrast is correctly defined based on the input conditions
  contrast <- c("condition", condition1, condition2)
  res <- as.data.frame(results(dds, alpha = 0.05, contrast = contrast))
  
  res$gene <- rownames(res)
  res$change <- "NO"
  res$change <-   ifelse (res$padj < .05 & res$log2FoldChange > 1, "UP", res$change)
  res$change <-   ifelse (res$padj < .05 & res$log2FoldChange < -1, "DW", res$change)
  res$change <-   factor (res$change, levels = c("UP","DW","NO"))
  
  return(res)
}

# function to create volcano plots
create_volcano_plot <- function(res, lfc_cap = 5, padj_cap = 50, lfc_threshold = 1, padj_threshold = 0.05, return_data = FALSE) {
  
  res$log_padj <- -log10(res$padj)

  p <- ggplot(res, aes(x = squish(log2FoldChange, range = c(-lfc_cap, lfc_cap)), y = squish(log_padj, range = c(0, padj_cap)), color = change)) +
    geom_point(size = 1, shape = 16, alpha = 0.4) +
    scale_color_manual(values = c("#E15759", "#4E79A7", "#79706E")) +
    theme_classic() +
    geom_vline(xintercept = c(-lfc_threshold, lfc_threshold), linetype = "dashed", color = "black") +
    geom_hline(yintercept = -log10(padj_threshold), linetype = "dashed", color = "black") +
    theme(legend.position = "none", strip.text = element_blank()) +
    xlab("log2 fold change") +
    ylab("-log10 adjusted p-value") +
    xlim(-lfc_cap, lfc_cap) +
    coord_cartesian(ylim = c(0, padj_cap))
  
  if (return_data) {
    return(plot = res)
  } else {
    return(p)
  }
}


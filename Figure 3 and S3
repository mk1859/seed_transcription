# differential accumulation of new mRNAs upon cycloheximide treatment (Fig. 3C-D)
# function for analysis of differential new mRNA levels
deg_new <- function(counts_matrix, coldata, rows1, rows2, 
                    min_counts = 4, normalization_genes) {
  
  # subset coldata based on row numbers
  coldata_subset <- coldata[c(rows1, rows2), ]
  
  # subset counts matrix to match the subsetted coldata
  counts_matrix_subset <- counts_matrix[, coldata_subset$lib]
  
  condition1 <- as.character(unique(coldata$condition[rows1])) #Extract condition names for the contrast
  condition2 <- as.character(unique(coldata$condition[rows2]))
  
  dds <- DESeqDataSetFromMatrix(countData = counts_matrix_subset, 
                                colData = coldata_subset, 
                                design = ~ condition)
  
  dds <- estimateSizeFactors(dds, controlGenes = rownames(counts_matrix_subset) %in% normalization_genes)
  
  dds <- dds[rowSums(counts(dds) >= min_counts) >= min_counts, ]
  
  dds <- DESeq(dds)
  
  # ensure the contrast is correctly defined based on the input conditions
  contrast <- c("condition", condition1, condition2)
  res <- as.data.frame(results(dds, alpha = 0.05, contrast = contrast))
  
  res$gene <- rownames(res)
  res$change <- "NO"
  res$change <-   ifelse (res$padj < .05 & res$log2FoldChange > 1, "UP", res$change)
  res$change <-   ifelse (res$padj < .05 & res$log2FoldChange < -1, "DW", res$change)
  res$change <-   factor (res$change, levels = c("UP","DW","NO"))
  
  return(res)
}


zscore_temp_inp <- t(scale(t(cpm)))
colnames(zscore_temp_inp) <- colnames(cpm)
rownames(zscore_temp_inp) <- rownames(cpm)

# clustering and heatmap for genes affected during imbibition (Fig. S4C)

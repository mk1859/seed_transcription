# function to process peaks
process_genomic_ranges <- function(gr1, gr2, gr3, ara_gr, min_overlap = 100, min_length = 200) {
  
  peak_a <- GenomicRanges::intersect(gr1, gr2) %>%
    .[lengths(.) > min_length]
  
  peak_b <- GenomicRanges::intersect(gr1, gr3) %>%
    .[lengths(.) > min_length]
  
  peak_c <- GenomicRanges::intersect(gr2, gr3) %>%
    .[lengths(.) > min_length]
  
  peak <- c(peak_a, peak_b, peak_c) %>%
    GenomicRanges::reduce()
  
  peak <- findOverlaps(peak, ara_gr, minoverlap = min_overlap) %>%
    as.data.frame() %>%
    pull(subjectHits) %>%
    names(ara_gr)[.] %>%
    unique()
  
  return(peak)
}


# calculate CPMs and mean CPMs for mRNAs and spike-ins
cpm <- new_1
depth <- colSums(cpm)
cpm <- t(t(cpm) / depth) * 10^6
cpm <- as.data.frame(t(cpm))
cpm$condition <- factor(gsub('.{0,2}$', '', rownames(cpm)))
cpm <- as.data.frame(t(apply (cpm [,-ncol(cpm)], 2, function (x) {
  tapply (x, cpm$condition, mean)})))

top_proportions <- function(values, fractions) {
  sorted_vals <- sort(values, decreasing = TRUE)
  indices <- round(fractions * length(sorted_vals))
  sapply(indices, function(p) {
    sum(sorted_vals[1:p]) / sum(values) })
}


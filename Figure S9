# plot showing that mRNAs identified as stable in ERCC-based mRNA stability analysis tend to be upregulated during imbibition (Fig. S9C)

coldata <- data.frame(lib = colnames (stabil),
                      condition = substr (colnames (stabil), 1, 4),
                      replicate = substr (colnames (stabil), 6, 6))

ercc <- rownames (stabil)[grep ("ERCC", rownames(stabil))]

dds <- DESeqDataSetFromMatrix(countData = stabil, colData = coldata, design = ~ condition)
dds <- estimateSizeFactors(dds, controlGenes= rownames(stabil) %in% ercc)
dds <- DESeq(dds)

res <- results(dds, alpha = 0.05, contrast = c("condition", "M_6h", "D_0h"), lfcThreshold = log2(2),altHypothesis = "lessAbs")

stab_test <- rownames(res[which(res$padj < 0.05), ])
stab_test <- stab_test [which(stab_test %in% ara$gene)]

plot <- as.data.frame(deg_alpha$M_06_00)
plot <- plot [which(plot$baseMean > 1),] # filter for expressed genes
plot <- plot [which(plot$gene %in% ara$gene),] # slect protein coding
plot$stable <- ifelse (plot$gene %in% stab_test, "Y", "N")

ggplot(plot, aes(x = stable, y = log2FoldChange, fill = stable)) +
  geom_boxplot() +
  theme_classic() +
  scale_fill_manual(values=c("#7f9bb0","#e15759")) +
  theme(legend.position = "none")

t.test (plot$log2FoldChange [which(plot$stable == "Y")], plot$log2FoldChange [which(plot$stable == "N")])$p.value

## Comparison of different labelling experiments (Fig. S9D).

# functions for generating pair comparisons and plotting them

compare_new_labeled <- function(new1, new2, name1, name2) { 
  plot_data <- merge(new1, new2, by = "gene") %>%
    mutate(
      change_comm = case_when(
        change.x == "NEW" & change.y == "NEW" ~ "BOTH",
        change.x == "NEW" | change.y == "NEW" ~ "SINGLE",
        TRUE ~ "NO"
      ),
      change_comm = factor(change_comm, levels = c("BOTH", "SINGLE", "NO"))
    )
  
  p <- ggplot(plot_data, aes(x = log2FoldChange.x, y = log2FoldChange.y, color = change_comm)) +
    geom_point(size = 0.1) + 
    theme_classic() +
    xlim(-4, 9) +
    ylim(-4, 9) + 
    scale_color_manual(values = c("#E15759", "#4E79A7", "#79706E")) +
    labs(x = paste("log2FC -", name1), 
         y = paste("log2FC -", name2)) +
    theme(legend.position = "none")
  
  return(p)
}

create_comparison_grid <- function(data_list) {
  list_names <- names(data_list)
  pairs <- combn(seq_along(data_list), 2, simplify = FALSE)
  
  plot_list <- lapply(pairs, function(p) {
    compare_new_labeled(
      new1 = data_list[[p[1]]], 
      new2 = data_list[[p[2]]], 
      name1 = list_names[p[1]], 
      name2 = list_names[p[2]]
    )
  })
  
  combined_plot <- wrap_plots(plot_list, ncol = length (data_list)-1)
  
  return(combined_plot)
}

